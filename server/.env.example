# Copy to ".env" (setup.sh does this for you) and fill in.

# The user + password your Obsidian plugin will use to connect.
WEBDAV_USER=obsidian
WEBDAV_PASSWORD=change-me-to-a-long-random-password

# Domain name pointing (A record) at this VPS. Enables automatic HTTPS, which iOS requires.
# Leave as-is if you only test over http on the local network (desktop/Android only).
DOMAIN=vault.example.com
