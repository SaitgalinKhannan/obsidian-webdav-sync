# Copy to ".env" (setup.sh does this for you) and fill in.

# Dedicated WebDAV credentials the Obsidian plugin will use.
# Use a NEW long password — never your root/SSH password.
WEBDAV_USER=obsidian
WEBDAV_PASSWORD=change-me-to-a-long-random-password

# Cloudflare Tunnel connector token.
# Cloudflare Zero Trust -> Networks -> Tunnels -> your tunnel:
# copy the value after "--token" from the install command (starts with eyJ...).
TUNNEL_TOKEN=eyJ...
